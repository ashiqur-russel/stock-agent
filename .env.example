## Local development environment variables (DO NOT put real secrets here)
#
# Copy this file to `.env` and fill in values on your machine.
# Never commit `.env` to git.
#
# Backend API base URL (used by frontend or tooling, if applicable)
BACKEND_URL=http://localhost:8000

# Groq (AI)
GROQ_API_KEY=
# Optional fair-share tuning (defaults match Groq Free / llama-4-scout); see backend/.env.example
# GROQ_ORG_RPM=30 GROQ_ORG_RPD=1000 GROQ_ORG_TPM=30000 GROQ_ORG_TPD=500000 GROQ_QUOTA_ENABLED=1 GROQ_QUOTA_BUCKET=day

# Optional: OpenAI (if you support it)
OPENAI_API_KEY=
