# Application
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Stock API (Alpha Vantage - get free key at https://www.alphavantage.co)
ALPHA_VANTAGE_API_KEY=demo

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Security
BCRYPT_SALT_ROUNDS=12
