## Backend environment variables (DO NOT put real secrets here)
#
# Copy this file to `backend/.env` and fill in values on your machine.
# Never commit `backend/.env` to git.
#
# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=sqlite:///./portfolio.db

# Auth
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email (SMTP) - use an App Password if applicable
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Groq (AI)
GROQ_API_KEY=

# Optional: Resend (email verification)
RESEND_API_KEY=

