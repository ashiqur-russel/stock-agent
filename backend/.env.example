## Backend environment variables (DO NOT put real secrets here)
#
# Copy this file to `backend/.env` and fill in values on your machine.
# Never commit `backend/.env` to git.
#
# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Comma-separated list of allowed origins — MUST include your Vercel frontend URL on Render.
# Without this, push subscribe and other API calls from the browser will be blocked by CORS.
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
# Public URL of the Next.js app (verification links). No trailing slash.
# FRONTEND_URL=https://your-app.vercel.app

# Database
# Local: SQLite (default)
DATABASE_PATH=./portfolio.db
# Production (e.g. Supabase): if set, must start with postgresql or postgres
# On Render, avoid *only* the Direct db.*.supabase.co:5432 URI (often IPv6); use the
# Session or Transaction *pooler* string from Supabase → Settings → Database instead.
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Auth
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email (SMTP) - use an App Password if applicable
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
# Inbox display name (still sends as SMTP_USER; required by most providers)
# SMTP_FROM_NAME=Stock Agent
SMTP_USE_TLS=true

# Groq (AI)
GROQ_API_KEY=

# Web Push / VAPID (browser push notifications)
# Generate once:  python tools/generate_vapid_keys.py
# Leave blank to disable browser push (email + WebSocket toasts still work)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:your@email.com

# Alert scan interval (minutes, default 30)
# ALERT_INTERVAL_MINUTES=30

# Optional: Resend (email verification)
RESEND_API_KEY=
